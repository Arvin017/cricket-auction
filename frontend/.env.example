# Copy this to .env.production and fill in your real deployed backend URL
# before building for production (npm run build). Not needed for local dev
# — vite.config.js already proxies /api and /ws-sockjs to localhost:8080.

VITE_API_BASE_URL=https://your-backend-url.up.railway.app/api
VITE_WS_URL=https://your-backend-url.up.railway.app/ws-sockjs
